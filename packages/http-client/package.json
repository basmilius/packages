{
    "name": "@basmilius/http-client",
    "description": "Http client for Vue projects.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "funding": "https://github.com/sponsors/basmilius",
    "homepage": "https://github.com/basmilius/packages",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/basmilius/packages.git",
        "directory": "packages/http-client"
    },
    "keywords": [
        "http",
        "http client",
        "http dto",
        "dto",
        "vue",
        "vue 3"
    ],
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch"
    },
    "files": [
        "dist",
        "src",
        "CODEOWNERS",
        "LICENSE"
    ],
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./vite": {
            "types": "./dist/vite.d.mts",
            "default": "./dist/vite.mjs"
        }
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "dependencies": {
        "@basmilius/utils": "workspace:*"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.1",
        "luxon": "^3.7.2",
        "tsdown": "^0.22.0",
        "vite": "^8.0.14",
        "vue": "^3.6.0-beta.12"
    },
    "peerDependencies": {
        "luxon": "^3.7.2",
        "vite": ">=5",
        "vue": "^3.6.0-beta.12"
    },
    "peerDependenciesMeta": {
        "vite": {
            "optional": true
        }
    }
}
