{
    "name": "@basmilius/routing",
    "description": "Vue Router wrapper with overlay, modal and slide-over routing.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "funding": "https://github.com/sponsors/basmilius",
    "homepage": "https://github.com/basmilius/packages",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/basmilius/packages.git",
        "directory": "packages/routing"
    },
    "keywords": [
        "routing",
        "vue",
        "vue-router",
        "overlay",
        "modal",
        "slide-over"
    ],
    "scripts": {
        "build": "tsgo --noEmit && tsdown"
    },
    "files": [
        "dist",
        "src",
        "CODEOWNERS",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./*": "./*"
    },
    "dependencies": {
        "lodash-es": "^4.18.1"
    },
    "peerDependencies": {
        "vue": "^3.6.0-beta.17",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@types/lodash-es": "^4.17.12",
        "tsdown": "^0.22.3",
        "vue": "^3.6.0-beta.17",
        "vue-router": "^5.1.0"
    }
}
