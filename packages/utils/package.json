{
    "name": "@basmilius/utils",
    "description": "Various utilities that are used in personal projects.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "funding": "https://github.com/sponsors/basmilius",
    "homepage": "https://github.com/basmilius/packages",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/basmilius/packages.git",
        "directory": "packages/utils"
    },
    "keywords": [
        "tools",
        "build",
        "node",
        "bun",
        "oxc"
    ],
    "scripts": {
        "build": "tsgo --noEmit && tsdown"
    },
    "files": [
        "dist",
        "src",
        "CODEOWNERS",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./*": "./*"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.2",
        "@types/node": "^26.0.1",
        "luxon": "^3.7.2",
        "tsdown": "^0.22.3"
    },
    "peerDependencies": {
        "luxon": "^3.7.2"
    }
}
