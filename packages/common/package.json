{
    "name": "@basmilius/common",
    "description": "Common code shared in personal projects.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "funding": "https://github.com/sponsors/basmilius",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/basmilius/packages.git",
        "directory": "packages/common"
    },
    "keywords": [
        "common",
        "bun",
        "vue",
        "store",
        "pinia",
        "router"
    ],
    "files": [
        "dist",
        "src",
        "CODEOWNERS",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsgo --noEmit && bun -b build.ts"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "typings": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./*": "./*"
    },
    "dependencies": {
        "@basmilius/http-client": "workspace:*",
        "@basmilius/utils": "workspace:*",
        "@flux-ui/components": "^3.0.0-next.26",
        "@flux-ui/internals": "^3.0.0-next.26",
        "pinia": "^3.0.4",
        "vue": "^3.6.0-beta.6",
        "vue-router": "^5.0.3"
    },
    "devDependencies": {
        "@basmilius/tools": "workspace:*",
        "@types/culori": "^4.0.1",
        "@types/lodash-es": "^4.17.12",
        "culori": "^4.0.2",
        "lodash-es": "^4.17.23"
    }
}
